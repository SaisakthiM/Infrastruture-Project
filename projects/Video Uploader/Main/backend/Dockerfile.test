# Dockerfile.test — Java/Spring Boot, only for running tests, never deployed
FROM maven:3.9-eclipse-temurin-21-alpine AS test

WORKDIR /app

# Copy pom.xml first (cached layer — only rebuilds if dependencies change)
COPY pom.xml .
RUN --mount=type=cache,id=mvn-cache,target=/root/.m2 \
    mvn dependency:go-offline -q

# Copy source
COPY src ./src

# Run tests — exits with code 1 if any test fails
CMD ["mvn", "test"]
